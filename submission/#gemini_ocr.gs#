// =============================================
// Gemini API によるマークシート読み取り
// スクリプトプロパティ: GEMINI_API_KEY
// =============================================

const GEMINI_API_URL = 'https://generativelanguage.googleapis.com/v1beta/models/gemini-2.5-flash:generateContent';

// DEFAULT_PROMPT: gemini_ocr用プロンプト
const DEFAULT_PROMPT =
  'このレポートの1ページ目にあるマークシートを読み取ってください。\n' +
  'マークシートの構成：\n' +
  '- クラス行：E または J のどちらかが塗りつぶされている\n' +
  '- 十の位：0〜9のいずれか1つが塗りつぶされている\n' +
  '- 一の位：0〜9のいずれか1つが塗りつぶされている\n\n' +
  '塗りつぶされているマスを実際に読み取り、以下のJSON形式のみで返してください。\n' +
  '{"class":"<EまたはJ>","tens":<十の位の数字>,"ones":<一の位の数字>}\n\n' +
  'classはEまたはJのどちらか。tens・onesはそれぞれ0〜9の整数。余分な説明は不要。';

// =============================================
// ① 疎通テスト（URLフェッチのみ）
// GASエディタから直接実行して動作確認する
// =============================================
function testGeminiConnection() {
  const apiKey = PropertiesService.getScriptProperties().getProperty('GEMINI_API_KEY');
  if (!apiKey) {
    Logger.log('ERROR: GEMINI_API_KEY がスクリプトプロパティに未設定です');
    return;
  }

  const url = GEMINI_API_URL + '?key=' + apiKey;
  const payload = {
    contents: [{
      parts: [{ text: 'こんにちは。「OK」とだけ返してください。' }]
    }]
  };

  const response = UrlFetchApp.fetch(url, {
    method: 'post',
    contentType: 'application/json',
    payload: JSON.stringify(payload),
    muteHttpExceptions: true
  });

  const status = response.getResponseCode();
  const body   = JSON.parse(response.getContentText());

  Logger.log('HTTP status: ' + status);
  Logger.log(JSON.stringify(body, null, 2));

  if (status === 200) {
    const text = body.candidates?.[0]?.content?.parts?.[0]?.text || '(empty)';
    Logger.log('Gemini の返答: ' + text);
  } else {
    Logger.log('ERROR: ' + (body.error?.message || response.getContentText()));
  }
}

// =============================================
// ② マークシート読み取り
// 引数:
//   fileBase64 ... PDFまたは画像のBase64文字列（データURLのヘッダー不要）
//   mimeType   ... 'application/pdf' or 'image/jpeg'
// 戻り値:
//   { class: 'E', number: 12 }
//   { error: '...' }
// =============================================
function readMarksheet(fileBase64, mimeType) {
  const apiKey = PropertiesService.getScriptProperties().getProperty('GEMINI_API_KEY');
  if (!apiKey) return { error: 'GEMINI_API_KEY がスクリプトプロパティに未設定です' };

  const url = GEMINI_API_URL + '?key=' + apiKey;

  const prompt = DEFAULT_PROMPT;

  const payload = {
    contents: [{
      parts: [
        { text: prompt },
        { inline_data: { mime_type: mimeType, data: fileBase64 } }
      ]
    }],
    generationConfig: {
      temperature: 0,
      response_mime_type: 'application/json'
    }
  };

  const response = UrlFetchApp.fetch(url, {
    method: 'post',
    contentType: 'application/json',
    payload: JSON.stringify(payload),
    muteHttpExceptions: true
  });

  const status = response.getResponseCode();
  if (status !== 200) {
    const err = JSON.parse(response.getContentText());
    return { error: 'API error ' + status + ': ' + (err.error?.message || response.getContentText()) };
  }

  const body = JSON.parse(response.getContentText());
  const text = body.candidates?.[0]?.content?.parts?.[0]?.text || '';

  try {
    const result = JSON.parse(text);
    // 簡易バリデーション
    if (!['E', 'J'].includes(result.class)) return { error: '不正なクラス値: ' + result.class };
    if (typeof result.tens !== 'number' || result.tens < 0 || result.tens > 9) {
      return { error: '不正な十の位: ' + result.tens };
    }
    if (typeof result.ones !== 'number' || result.ones < 0 || result.ones > 9) {
      return { error: '不正な一の位: ' + result.ones };
    }
    return result; // { class: 'E', tens: 1, ones: 2 }
  } catch (e) {
    return { error: '応答のJSONパース失敗', raw: text };
  }
}

// =============================================
// ③ テストUI用：プロンプトを返す（HTMLに初期値として渡す）
// =============================================
function getDefaultPrompt() {
  return DEFAULT_PROMPT;
}

// =============================================
// ④ テストUI用：カスタムプロンプトでマークシート読み取り
// AI_PROVIDER プロパティでプロバイダーを切り替え
// 戻り値: { parsed, raw, status, provider, error }
// =============================================
function runMarksheetTest(fileBase64, mimeType, customPrompt, provider) {
  if (!provider) {
    provider = PropertiesService.getScriptProperties().getProperty('AI_PROVIDER') || 'gemini';
  }
  if (provider === 'claude') {
    return runMarksheetTestClaude(fileBase64, mimeType, customPrompt);
  }

  const apiKey = PropertiesService.getScriptProperties().getProperty('GEMINI_API_KEY');
  if (!apiKey) return { error: 'GEMINI_API_KEY が未設定です' };

  const url    = GEMINI_API_URL + '?key=' + apiKey;
  const prompt = customPrompt || DEFAULT_PROMPT;

  const payload = {
    contents: [{
      parts: [
        { text: prompt },
        { inline_data: { mime_type: mimeType, data: fileBase64 } }
      ]
    }],
    generationConfig: { temperature: 0, responseMimeType: 'application/json' }
  };

  const response = UrlFetchApp.fetch(url, {
    method: 'post',
    contentType: 'application/json',
    payload: JSON.stringify(payload),
    muteHttpExceptions: true
  });

  const status = response.getResponseCode();
  const body   = JSON.parse(response.getContentText());
  const raw    = body.candidates?.[0]?.content?.parts?.[0]?.text || '';

  // マークダウンコードブロックを除去してからパース
  let parsed = null;
  try {
    const jsonStr = raw.replace(/^```[a-z]*\n?/i, '').replace(/\n?```$/, '').trim();
    parsed = JSON.parse(jsonStr);
  } catch (e) {}

  return { status, raw, parsed, provider: 'gemini' };
}

// =============================================
// ⑤ テスト用：DriveのファイルIDを使って動作確認
// GASエディタから直接実行してログを確認する
// =============================================
function testReadMarksheetFromDrive() {
  const FILE_ID = 'ここにDriveのファイルID'; // 手動で変更して実行

  const file     = DriveApp.getFileById(FILE_ID);
  const mimeType = file.getMimeType();
  const blob     = file.getBlob();
  const base64   = Utilities.base64Encode(blob.getBytes());

  Logger.log('ファイル名: ' + file.getName());
  Logger.log('MIMEタイプ: ' + mimeType);

  const result = readMarksheet(base64, mimeType);
  Logger.log('読み取り結果: ' + JSON.stringify(result));
}

